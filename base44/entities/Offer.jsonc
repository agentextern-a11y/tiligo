{
  "name": "Offer",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Offer/combo title"
    },
    "description": {
      "type": "string",
      "description": "Offer description"
    },
    "business_id": {
      "type": "string"
    },
    "business_name": {
      "type": "string"
    },
    "original_price": {
      "type": "number"
    },
    "offer_price": {
      "type": "number"
    },
    "image_url": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Products included in the combo"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "expires_at": {
      "type": "string",
      "format": "date"
    },
    "badge": {
      "type": "string",
      "enum": [
        "combo",
        "deal",
        "limited",
        "new"
      ],
      "default": "deal"
    }
  },
  "required": [
    "title",
    "offer_price",
    "business_id"
  ]
}